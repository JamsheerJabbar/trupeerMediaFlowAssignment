# =============================================
# MediaFlow Environment Variables
# =============================================

# --- Redis ---
REDIS_URL=redis://redis:6379              # Redis connection URL

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=minio:9000                 # MinIO API endpoint
MINIO_ACCESS_KEY=minioadmin               # MinIO access key
MINIO_SECRET_KEY=minioadmin               # MinIO secret key
MINIO_BUCKET=mediaflow                    # Bucket for all media files

# --- Gateway ---
DATABASE_PATH=/data/mediaflow.db          # SQLite database file path
MAX_CONCURRENT_JOBS=2                     # Max jobs per worker (used for capacity calc)
PRESSURE_THRESHOLD=0.8                    # Queue utilization threshold (0.0-1.0)
MAX_RETRIES=3                             # Max retry attempts before dead-lettering

# --- Timeouts (seconds) ---
TIMEOUT_OVERLAY=1200                      # Stale threshold for overlay stages (20 min)
TIMEOUT_TRANSCODE=900                     # Stale threshold for transcode stages (15 min)
TIMEOUT_EXTRACT=600                       # Stale threshold for extract stages (10 min)

# --- Background loops ---
WATCHDOG_INTERVAL_SECONDS=60              # Watchdog cycle interval
MONITOR_INTERVAL_SECONDS=30              # Queue monitor cycle interval

# --- Worker ---
JOB_TYPE=overlay                          # Worker job type: overlay | transcode | extract
GATEWAY_URL=http://gateway:8000           # Gateway API URL for worker callbacks
WORKER_HEARTBEAT_INTERVAL=10              # Heartbeat write interval (seconds)
WORKER_HEARTBEAT_TTL=15                   # Heartbeat key expiry (seconds)
